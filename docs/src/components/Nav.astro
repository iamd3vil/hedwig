---
const { active } = Astro.props;
const links = [
  { href: "/introduction", label: "Docs" },
  { href: "/configuration", label: "Configuration" },
  { href: "/reference/architecture", label: "Reference" }
];
const githubUrl = "https://github.com/iamd3vil/hedwig";
---

<nav class="nav">
  <div class="nav-inner">
    <a class="logo" href="/">
      <img src="/logo.png" alt="Hedwig logo" />
      <span>Hedwig</span>
    </a>
    <div class="nav-links">
      {links.map((link) => (
        <a class={active === link.href ? "active" : ""} href={link.href}>
          {link.label}
        </a>
      ))}
      <a class="cta" href="/quickstart">Quickstart</a>
      <a class="github-link" href={githubUrl} aria-label="Hedwig on GitHub" target="_blank" rel="noreferrer">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M12 2C6.48 2 2 6.58 2 12.22c0 4.52 2.87 8.35 6.84 9.71.5.09.68-.22.68-.49 0-.24-.01-1.05-.01-1.9-2.51.47-3.16-.63-3.36-1.2-.11-.29-.6-1.2-1.03-1.44-.35-.19-.85-.66-.01-.67.79-.01 1.35.74 1.54 1.04.9 1.55 2.34 1.11 2.91.85.09-.67.35-1.11.64-1.37-2.22-.26-4.55-1.14-4.55-5.05 0-1.11.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05A9.3 9.3 0 0 1 12 6.95c.85 0 1.71.12 2.51.34 1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.92-2.34 4.79-4.57 5.05.36.32.68.93.68 1.89 0 1.37-.01 2.47-.01 2.8 0 .27.18.59.69.49A10.15 10.15 0 0 0 22 12.22C22 6.58 17.52 2 12 2Z" />
        </svg>
      </a>
    </div>
  </div>
</nav>
